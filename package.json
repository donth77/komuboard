{
  "name": "komuboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "description": "Komuboard — free-to-run realtime collaborative whiteboard (web + mobile + VR). M0 foundations.",
  "scripts": {
    "dev": "concurrently -n worker,web -c blue,green \"pnpm --filter @komuboard/worker dev\" \"pnpm --filter @komuboard/client-web dev\"",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --if-present test",
    "test:e2e": "playwright test",
    "deploy": "pnpm --filter @komuboard/worker deploy"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
